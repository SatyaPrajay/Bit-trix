# your testbench to ensure functionality...
import cocotb
from cocotb.clock import Clock
from cocotb.triggers import RisingEdge, Timer
import os

# Clock period (10 ns)
CLK_PERIOD_NS = 10

# Program file generated by opcode_gen.py
PROGRAM_FILE = "program.asm"

# Test case parameters
L = 10  # length of sequences (must match what was used to generate program)
X_START = 0
Y_START = L
H_START = 2 * L
CONST_TABLE_START = 3 * L

# Example input sequences (can be changed)
x = [1, 2, 1, 3, 2, 1, 1, 2, 1, 1]   # x[n] for n=0..L-1
y = [2, 5, 4, 9, 8, 5, 4, 7, 5, 4]   # y[n] for n=0..L-1

# Compute expected h[n] using standard convolution
def compute_expected_h(x, y):
    # h[0] = y[0] / x[0]
    h = [0] * len(x)
    h[0] = y[0] // x[0]
    for n in range(1, len(x)):
        s = sum(x[k] * h[n - k] for k in range(1, n+1))
        h[n] = (y[n] - s) // x[0]
    return h

expected_h = compute_expected_h(x, y)

# ----------------------------------------------------------------------
# Reset DUT
# ----------------------------------------------------------------------
async def reset_dut(dut):
    dut.rst.value = 1
    for _ in range(5):
        await RisingEdge(dut.clk)
    dut.rst.value = 0
    await RisingEdge(dut.clk)   # one cycle after reset

# ----------------------------------------------------------------------
# Write data to RAM via cocotb (by driving the top's internal signals)
# We directly set mem array in ram instance (if accessible) or use store instructions.
# Simpler: use the DUT's memory interface by manually driving store operations.
# We'll write to RAM by creating a sequence of store instructions.
# But that would be messy. Instead we can use cocotb's ability to peek/poke internal
# signals if the hierarchy is known. We'll assume the RAM module is instantiated
# as "data_ram" in the top. We'll write to its internal mem array via
# dut.data_ram.mem. This is simulation-only and works with cocotb.
# ----------------------------------------------------------------------
async def init_ram(dut):
    # Write x[n] to addresses X_START..X_START+L-1
    for i, val in enumerate(x):
        dut.data_ram.mem[X_START + i] = val
    # Write y[n] to addresses Y_START..Y_START+L-1
    for i, val in enumerate(y):
        dut.data_ram.mem[Y_START + i] = val
    # Write constant table: addresses for x[i], y[i], h[i]
    # Addresses for x[0..L-1]
    for i in range(L):
        dut.data_ram.mem[CONST_TABLE_START + X_START + i] = X_START + i
    # Addresses for y[0..L-1]
    for i in range(L):
        dut.data_ram.mem[CONST_TABLE_START + Y_START + i] = Y_START + i
    # Addresses for h[0..L-1]
    for i in range(L):
        dut.data_ram.mem[CONST_TABLE_START + H_START + i] = H_START + i
    # Also store constant 1 at some location if needed (not used in our program)
    # Optionally, we can store the constant 1 at CONST_TABLE_START + 3L, but our program doesn't use it.
    # We'll still set it to avoid any unwanted reads.
    dut.data_ram.mem[CONST_TABLE_START + 3*L] = 1

# ----------------------------------------------------------------------
# Read back computed h[n] from RAM
# ----------------------------------------------------------------------
async def read_h(dut):
    h = []
    for i in range(L):
        h.append(dut.data_ram.mem[H_START + i])
    return h

# ----------------------------------------------------------------------
# Feed instructions from program file
# ----------------------------------------------------------------------
async def run_program(dut, instr_list):
    for instr in instr_list:
        dut.instr.value = int(instr, 2)
        await RisingEdge(dut.clk)
    # After last instruction, feed NOPs for a few cycles to let final writes complete
    for _ in range(5):
        dut.instr.value = 0
        await RisingEdge(dut.clk)

# ----------------------------------------------------------------------
# Main test
# ----------------------------------------------------------------------
@cocotb.test()
async def test_impulse_response(dut):
    # Start clock
    cocotb.start_soon(Clock(dut.clk, CLK_PERIOD_NS, units="ns").start())

    # Enable waveform dump (optional)
    dut._log.info("Dumping waveform to dump.vcd")
    cocotb.start_soon(cocotb.start_soon(cocotb.start_soon(
        # Actually cocotb has a built-in way: use `cocotb.fork`? Simpler: just add the following line
        # but it may not work in all simulators. For Verilator, we need to enable VCD in the simulation command.
        # We'll just note that we want to dump.
    )))
    # For Verilator, you usually need to add --trace to the command line.
    # We'll just log a message.
    dut._log.info("For waveform, run simulation with --trace and open dump.vcd in gtkwave.")

    # Reset DUT
    await reset_dut(dut)

    # Initialise RAM with test data
    await init_ram(dut)
    dut._log.info("RAM initialised with x and y sequences and constant table.")

    # Read program instructions
    with open(PROGRAM_FILE, "r") as f:
        instr_lines = [line.strip() for line in f if line.strip()]
    instr_list = instr_lines  # each line is an 8-bit binary string

    dut._log.info(f"Loaded {len(instr_list)} instructions from {PROGRAM_FILE}")

    # Run the program
    await run_program(dut, instr_list)

    # Read back computed h[n]
    h_computed = await read_h(dut)

    # Compare with expected
    dut._log.info("=" * 50)
    dut._log.info("IMPULSE RESPONSE RESULTS")
    dut._log.info("=" * 50)
    dut._log.info(f"{'n':<4} {'Expected':<10} {'Computed':<10} {'Match?'}")
    all_match = True
    for i in range(L):
        match = "✓" if h_computed[i] == expected_h[i] else "✗"
        dut._log.info(f"{i:<4} {expected_h[i]:<10} {h_computed[i]:<10} {match}")
        if h_computed[i] != expected_h[i]:
            all_match = False

    if all_match:
        dut._log.info("✓ All values match!")
    else:
        dut._log.error("✗ Mismatch detected!")

    # Read cycle count
    total_cycles = int(dut.cycle_count.value)
    total_time_ns = total_cycles * CLK_PERIOD_NS

    dut._log.info("=" * 50)
    dut._log.info("⏱️  SIMULATION SUMMARY")
    dut._log.info("=" * 50)
    dut._log.info(f"Total Cycles   : {total_cycles}")
    dut._log.info(f"Clock Period   : {CLK_PERIOD_NS} ns")
    dut._log.info(f"Total Time     : {total_time_ns} ns")
    dut._log.info(f"Instructions   : {len(instr_list)}")
    dut._log.info("=" * 50)

    # Optional: assert for pass/fail
    assert all_match, "Impulse response computation failed"

